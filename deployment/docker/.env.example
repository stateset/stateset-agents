# Copy to `.env` before running `docker compose`.

# Gateway
API_ENVIRONMENT=development
API_REQUIRE_AUTH=false
API_LOG_LEVEL=INFO

# Inference backend
# For local dev, the gateway defaults to `INFERENCE_BACKEND=stub` so it works
# without an external model server. If you're running vLLM elsewhere, switch to:
# INFERENCE_BACKEND=vllm
# INFERENCE_BACKEND_URL=http://localhost:8001
INFERENCE_BACKEND=stub
INFERENCE_BACKEND_URL=http://localhost:8001
INFERENCE_DEFAULT_MODEL=moonshotai/Kimi-K2.5

# Optional deps (only used when enabled via env vars)
POSTGRES_PASSWORD=change_me_strong
